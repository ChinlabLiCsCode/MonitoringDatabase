# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.

# ── InfluxDB ──────────────────────────────────────────────────────────────────
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=changeme_min8chars

# Keep these the same as the existing Synology InfluxDB so cutover only requires
# changing the URL in influxdb_credentials.json.
INFLUXDB_ORG=lics
INFLUXDB_INIT_BUCKET=mainLab

# Copy token from configs/influxdb_credentials.json on the Synology:
INFLUXDB_ADMIN_TOKEN=REPLACE_WITH_EXISTING_TOKEN

# ── Grafana (local) ───────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_min8chars

# ── Grafana Cloud ─────────────────────────────────────────────────────────────
# Find these at: grafana.com → your org → My Account → Stack → Prometheus → Details
#
# Remote Write Endpoint (looks like):
#   https://prometheus-prod-XX-prod-us-east-0.grafana.net/api/prom/push
GRAFANA_CLOUD_PROM_URL=https://prometheus-prod-XX-prod-REGION.grafana.net/api/prom/push

# Username shown on the Prometheus details page (a number, e.g. 123456)
GRAFANA_CLOUD_PROM_USER=123456

# API key: create one at grafana.com → your org → My Account → Access Policies
# Grant it "metrics:write" scope
GRAFANA_CLOUD_PROM_KEY=glc_eyXXXXXXXXXXXXXXXXXXXXXXXXXXXX
